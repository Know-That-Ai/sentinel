# GitHub
GITHUB_PAT=ghp_...
GITHUB_ORG=your-org-or-username
GITHUB_USERNAME=your-github-handle
WEBHOOK_SECRET=generate-a-random-string

# Scanner bots
SCANNER_BOT_LOGINS=cursor-bugbot[bot],github-advanced-security[bot]

# Server
PORT=3847

# Agents
PREFERRED_AGENT=claude-code

# OpenClaw
OPENCLAW_URL=http://localhost:4000
OPENCLAW_API_KEY=
OPENCLAW_GITHUB_LOGINS=openclaw-bot,rose-agent

# Repo path mappings (JSON string)
REPO_PATHS={"owner/repo":"/absolute/local/path"}

# Auto-dispatch
AUTO_DISPATCH_BUGBOT=false
AUTO_DISPATCH_CODEQL=false
AUTO_DISPATCH_CI=false

# Tmux (optional) — only set if you actually run Claude inside a named tmux pane
# SENTINEL_DEFAULT_TMUX_PANE=sentinel:0.1

# Injection mode — true (default) focuses the linked tab and presses Enter
# so Claude starts immediately; false types the trigger line only and you
# press Enter yourself. Terminal.app always submits.
SENTINEL_AUTO_SUBMIT=true

# Smee (dev webhook proxy — get a URL from https://smee.io)
SMEE_URL=https://smee.io/YOUR_CHANNEL_ID

# Multi-user
SENTINEL_USER_LABEL=brian
